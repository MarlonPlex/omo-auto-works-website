<header class="border-b border-gray-200 bg-white md:hidden relative w-full px-6 py-4 z-10">
    <div class="flex justify-between items-center">
        <!-- Logo -->
        <a href="/">
            <img 
                src="./imgs/omo_aw_logo.png" 
                alt="omo auto work logo"
                class="max-w-[80px] object-contain"
            ></img>
        </a>
        <!-- Open Menu Button-->    
        <button id="menu-btn" class="p-1" aria-label="open menu">
            <svg id="menu-open-icon" class="w-[40px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path fill-rule="evenodd" d="M3 6.75A.75.75 0 0 1 3.75 6h16.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 6.75ZM3 12a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 12Zm0 5.25a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
            </svg>
            <svg id="menu-close-icon" class="hidden w-[40px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path fill-rule="evenodd" d="M5.47 5.47a.75.75 0 0 1 1.06 0L12 10.94l5.47-5.47a.75.75 0 1 1 1.06 1.06L13.06 12l5.47 5.47a.75.75 0 1 1-1.06 1.06L12 13.06l-5.47 5.47a.75.75 0 0 1-1.06-1.06L10.94 12 5.47 6.53a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
        </button>
    </div>
</header>