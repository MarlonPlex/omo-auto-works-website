<!doctype html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link href="./styles/output.css" rel="stylesheet">
    </head>
    <body class="relative overflow-scroll">
{% include "md_and_up_header.njk" %}
        <div id="mobile-head-menu-wrapper" class="fixed top-[0] w-full z-50">
{% include "mobile_header.njk" %}
{% include "mobile_menu.njk" %}
        </div>
{% include "mobile_hero.njk" %}
{% include "md_and_up_hero.njk" %}
        <!--Contact details Bar-->
        <div class="flex justify-evenly mt-auto lg:px-24 md:px-16 px-6">
            <!-- Call Us -->
            <div class="flex flex-col items-center py-3">
                <div class="flex items-center gap-1">
                    <svg class="w-[12px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" className="size-6">
                        <path fillRule="evenodd" d="M1.5 4.5a3 3 0 0 1 3-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 0 1-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 0 0 6.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 0 1 1.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 0 1-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5Z" clipRule="evenodd" />
                    </svg>
                    <p class="font-bold sm:text-sm text-xs uppercase tracking-wide">
                        Call Us
                    </p>
                </div>
                <div class="md:hidden">
                    <p class="font-thin mt-1 text-gray-900 sm:text-sm text-xs">
                        (876) 863-0241
                    </p>
                    <p class="font-thin mt-1 text-gray-900 sm:text-sm text-xs">
                        (876) 542-5969
                    </p>
                </div>
                <div class="hidden md:block">
                    <p class="font-thin mt-1 text-gray-900 sm:text-sm text-xs">
                        (876) 863-0241 <b>OR</b> (876) 542-5969
                    </p>
                </div>
            </div>

            <!-- Visit Us -->
            <div class="flex flex-col items-center py-3">
                <div class="flex items-center gap-1">
                    <svg class="w-[15px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
                        <path fill-rule="evenodd" d="m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 0 0-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 0 0 2.682 2.282 16.975 16.975 0 0 0 1.145.742ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
                    </svg>

                    <p class="font-bold sm:text-sm text-xs uppercase tracking-wide text-black">
                        Visit Us
                    </p>
                </div>
                <div class="flex flex-col items-center md:hidden">
                    <p class="font-thin mt-1 text-gray-900 sm:text-sm text-xs">
                        10 3/4 Mckinley Road,
                    </p>
                    <p class="font-thin mt-1 text-gray-900 sm:text-sm text-xs">
                        Mandeville, Manchester
                    </p>
                </div>
                <div class="hidden md:block">
                    <p class="font-thin mt-1 text-gray-900 sm:text-sm text-xs">
                        10 3/4 Mckinley Road, Mandeville, Manchester.
                    </p>
                </div>
            </div>
        </div>
        <script src="./scripts/mobile_menu_toggle.js"></script>
