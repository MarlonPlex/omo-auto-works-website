        {% set images = [
            {
                before: "./imgs/service-body-work.jpeg",
                after: "./imgs/service-body-work.jpeg"
            },
            {
                before: "",
                after: ""
            },
            {
                before: "",
                after: ""
            },
            {
                before: "",
                after: ""
            },
            {
                before: "",
                after: ""
            },
            {
                before: "",
                after: ""
            }
        ] %}
        <!--Our Work Section-->
        <section class="bg-gray-200">
            <h1 class="font-bold text-center text-3xl pt-5">Our Work</h1>
            <div class="px-4 py-5">
                <!-- Before and After Content -->
                <div class="overflow-hidden">
                    <div 
                        id="our-work-track" 
                        class="flex transition-transform duration-300 ease-in-out"
                        style="transform: translateX(calc(50% - 144px))"
                    >
                        <!-- Tiles -->
                        {% for image in images %}
                        <div class="w-full md:max-w-2xs flex-shrink-0 overflow-hidden rounded-lg border border-gray-200 bg-neutral-700">
                            <div class="aspect-[4/5]">
                                <div class="flex h-full flex-col">
                                    <!-- Before -->
                                    <div class="relative flex-1">
                                        <img
                                        src="{{ image.before }}"
                                        alt="Before"
                                        class="aspect-[16/9] h-full w-full object-cover"
                                        />
                                        <span class="absolute left-3 top-3 rounded bg-black/75 px-2 py-1 text-xs font-medium text-white">
                                        Before
                                        </span>
                                    </div>

                                    <!-- After -->
                                    <div class="relative flex-1">
                                        <img
                                        src="{{ image.after }}"
                                        alt="After"
                                        class="aspect-[16/9] h-full w-full object-cover"
                                        />
                                        <span class="absolute left-3 top-3 rounded bg-black/75 px-2 py-1 text-xs font-medium text-white">
                                        After
                                        </span>
                                    </div>

                                </div>
                            </div>
                        </div>
                        {% endfor %}            
                    </div>
                </div>

                </div>
                <!--Track Controls-->
                <div class="mt-6 flex items-center justify-between px-2">
                    {# Prev arrow #}
                    <button
                        id="our-work-prev"
                        aria-label="Our work service"
                        class="text-neutral-500 disabled:opacity-30"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                        </svg>
                    </button>

                    {# Dots #}
                    <div id="our-work-dots" class="flex items-center gap-3" role="tablist">
                        {% for image in images %}
                        <button
                        role="tab"
                        aria-label="Go to slide {{ loop.index }}"
                        data-index="{{ loop.index0 }}"
                        class="h-4 w-4 rounded-full border-2 border-neutral-500 transition-colors duration-200 {% if loop.first %}bg-neutral-500 border-neutral-500{% else %}bg-transparent{% endif %}"
                        ></button>
                        {% endfor %}
                    </div>

                    {# Next arrow #}
                    <button
                        id="our-work-next"
                        aria-label="Next before and after image"
                        class="text-neutral-500 disabled:opacity-30"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                        </svg>
                    </button>
                </div>
            </div>
        </section>